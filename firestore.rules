rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function uid()     { return request.auth.uid; }
    function role()    { return get(/databases/$(database)/documents/users/$(uid())).data.role; }
    function isAdmin() { return isAuth() && role() == "admin"; }
    function isStaff() { return isAuth() && (role() == "staff" || role() == "admin"); }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if true;  // needed for displayName uniqueness check before login
      allow create: if isAuth() && uid() == userId;
      allow update: if uid() == userId || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Players ───────────────────────────────────────────────────────────────
    match /players/{playerId} {
      allow read:   if isAuth();
      allow create: if isAuth();  // user creates own player on register
      allow update: if isAuth();  // linking existing player also needs auth only
      allow delete: if isAdmin();
    }

    // ── Parts ─────────────────────────────────────────────────────────────────
    match /parts/{partId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Combos ────────────────────────────────────────────────────────────────
    match /combos/{comboId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.playerId == uid();
      allow update: if isAuth() && (resource.data.playerId == uid() || isStaff());
      allow delete: if isAdmin();
    }

    // ── ComboHistory ──────────────────────────────────────────────────────────
    match /comboHistory/{histId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── Leagues ───────────────────────────────────────────────────────────────
    match /leagues/{leagueId} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── Tournaments ───────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read:   if true;  // public (used by /t page)
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();

      // Groups
      match /groups/{groupId} {
        allow read:   if true;
        allow write:  if isStaff();
      }

      // Matches
      match /matches/{matchId} {
        allow read:   if true;
        // Score updates: staff only (backend validates judge)
        allow write:  if isStaff();
      }
    }
  }
}
